# OPENROUTER_API_KEY: Required for AI validation using NVIDIA Llama Nemotron.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# GEMINI_API_KEY: Required for Gemini AI features.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="gen-lang-client-xxxxxxxxxx"

# GOOGLE_EARTH_ENGINE_CLIENT_ID: Required for real satellite imagery.
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_EARTH_ENGINE_CLIENT_ID="xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_EARTH_ENGINE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# SENTINEL_HUB_CLIENT_ID: Alternative for satellite imagery.
# Get credentials at: https://apps.sentinel-hub.com/dashboard/#/account/settings
SENTINEL_HUB_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SENTINEL_HUB_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://your-app-url.example.com"
